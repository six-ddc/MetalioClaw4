{
    "target": "esp32p4",
    "builds": [
        {
            "name": "metalio-claw-4",
            "sdkconfig_append": [
                "CONFIG_LV_USE_FREETYPE=y",
                "CONFIG_LV_FREETYPE_CACHE_FT_GLYPH_CNT=768",
                "CONFIG_LV_DRAW_THREAD_STACK_SIZE=49152",
                "CONFIG_ESP_LVGL_ADAPTER_ENABLE_FREETYPE=y",
                "CONFIG_ESP_LVGL_ADAPTER_FREETYPE_MINIMAL_BUILD=y"
            ]
        }
    ]
}